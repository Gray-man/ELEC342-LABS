%Lucas Graham
%40249532
%Q1

period = input("Number of periods: ");
step = input("Step size of frequency interval: ");

w = [-period*pi:step:period*pi];
for i = 1:5
    sampling_rate = input("Input the sampling rate: ");
    N = floor(2*sampling_rate);
    n = 0 : (2*N - 1);
    x = sin((2*pi/N)*n);
    
    subplot(2,5,1)
    stem(n, x);
    ft = dtft(x, w);
    
    plot(w, abs(ft));
end

